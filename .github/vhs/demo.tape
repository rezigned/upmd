Output .github/pages/demos/demo.gif

Source ./.github/vhs/config.tape

# Launch upmd without any argument (file picker)
Type "upmd"
Enter
Sleep 1s

# Open demo file
Down 1
Sleep 0.5s
Up 1
Sleep 0.5s
Enter
Sleep 0.5s

# Go to 2nd block
Type "/"
Sleep 0.5s
Type "read -p"
Sleep 0.5s
Enter
Sleep 0.5s

# Run `read` command
Enter
Sleep 0.5s
Type "UPMD"
Sleep 0.5s
Enter
Sleep 1s
